{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "pluginAlias": "Dahua Gate Release",
  "pluginType": "platform",
  "singular": true,

  "schema": {
    "title": "Dahua Gate Release",
    "type": "object",

    "required": ["name", "ip", "username", "password"],

    "properties": {
      "name": {
        "type": "string",
        "title": "Accessory Name",
        "default": "Dahua Gate Release",
        "minLength": 1
      },

      "ip": {
        "type": "string",
        "title": "Intercom IP Address",
        "format": "ipv4",
        "placeholder": "192.168.1.50",
        "description": "The IP address of your Dahua VTO intercom."
      },

      "username": {
        "type": "string",
        "title": "Username",
        "minLength": 1,
        "placeholder": "admin"
      },

      "password": {
        "type": "string",
        "title": "Password",
        "minLength": 1,
        "format": "password",
        "placeholder": "••••••••"
      },

      "fallbackRetries": {
        "type": "integer",
        "title": "Retry Attempts on Failure",
        "description": "Number of times to retry the openDoor command if it fails.",
        "minimum": 0,
        "default": 1
      },

      "fallbackDelay": {
        "type": "integer",
        "title": "Retry Delay (ms)",
        "description": "Delay between retry attempts.",
        "minimum": 0,
        "default": 5000
      },

      "autoLockTime": {
        "type": "integer",
        "title": "Auto-lock Duration",
        "description": "Time before gate auto-locks. Set to 0 to disable.",
        "minimum": 0,
        "default": 0
      },

      "autoLockUnit": {
        "type": "string",
        "title": "Auto-lock Unit",
        "description": "Unit of time for auto-lock duration.",
        "enum": ["seconds", "hours", "days"],
        "default": "seconds"
      },

      "pollInterval": {
        "type": "integer",
        "title": "Poll Interval (ms)",
        "description": "How often to check intercom availability. Minimum 1000ms.",
        "minimum": 1000,
        "default": 60000
      },

      "verboseLogging": {
        "type": "boolean",
        "title": "Enable Verbose Logging",
        "description": "Show detailed debug logs in the Homebridge console.",
        "default": false
      }
    },

    "layout": [
      {
        "type": "fieldset",
        "title": "Connection Settings",
        "expandable": false,
        "items": ["name", "ip", "username", "password"]
      },
      {
        "type": "fieldset",
        "title": "Retry Logic",
        "expandable": true,
        "items": ["fallbackRetries", "fallbackDelay"]
      },
      {
        "type": "fieldset",
        "title": "Auto-lock Settings",
        "expandable": true,
        "items": ["autoLockTime", "autoLockUnit"]
      },
      {
        "type": "fieldset",
        "title": "Advanced Settings",
        "expandable": true,
        "items": ["pollInterval", "verboseLogging"]
      }
    ]
  }
}
